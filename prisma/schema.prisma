generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id     Int     @id @default(autoincrement())
  email  String  @unique
  name   String?
  tasks  Task[]
  boards Board[]
}

model Task {
  id       Int    @id @default(autoincrement())
  content  String
  group    String
  authorId Int
  author   User   @relation(fields: [authorId], references: [id])
}

model Board {
  id       Int  @id @default(autoincrement())
  content  Json
  authorId Int
  author   User @relation(fields: [authorId], references: [id])
}
